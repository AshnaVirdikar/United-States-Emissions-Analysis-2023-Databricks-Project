{
  "datasets": [
    {
      "name": "80ae2035",
      "displayName": "Location dataset",
      "queryLines": [
        "select latitude, longitude, `GHG emissions mtons CO2e` as emissions\r\n",
        "from emissions_data_2023"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "d3b049b8",
      "displayName": "Emissions per person",
      "queryLines": [
        "select county_state_name, population, \r\n",
        "       try_cast(replace(`GHG emissions mtons CO2e`, ',', '') as double) / \r\n",
        "       cast(population as double) as emissions_per_person\r\n",
        "from emissions_data_2023\r\n",
        "order by emissions_per_person desc\r\n",
        ";"
      ]
    },
    {
      "name": "80cb833c",
      "displayName": "Total Emissions per State",
      "queryLines": [
        "select state_abbr,\r\n",
        "       SUM(try_cast(replace(`GHG emissions mtons CO2e`, ',', '') as double) ) as Total_Emissions\r\n",
        "from emissions_data_2023\r\n",
        "Group By state_abbr\r\n",
        "order by Total_Emissions desc\r\n",
        "LIMIT 10\r\n",
        ";"
      ]
    },
    {
      "name": "b35bac59",
      "displayName": "County Shaming",
      "queryLines": [
        "select county_state_name, population, \r\n",
        "       try_cast(replace(`GHG emissions mtons CO2e`, ',', '') as double) AS Total_Emissions\r\n",
        "from emissions_data_2023\r\n",
        "order by Total_Emissions desc\r\n",
        "LIMIT 10\r\n",
        ";"
      ]
    },
    {
      "name": "summary_kpis",
      "displayName": "Summary KPIs",
      "queryLines": [
        "WITH state_emissions AS (\n",
        "  SELECT\n",
        "    state_abbr,\n",
        "    SUM(try_cast(replace(`GHG emissions mtons CO2e`, ',', '') as double)) as state_total\n",
        "  FROM\n",
        "    emissions_data_2023\n",
        "  GROUP BY\n",
        "    state_abbr\n",
        "),\n",
        "top_10_total AS (\n",
        "  SELECT\n",
        "    SUM(state_total) as top_10_sum\n",
        "  FROM\n",
        "    (\n",
        "      SELECT\n",
        "        state_total\n",
        "      FROM\n",
        "        state_emissions\n",
        "      ORDER BY\n",
        "        state_total DESC\n",
        "      LIMIT 10\n",
        "    )\n",
        "),\n",
        "overall_stats AS (\n",
        "  SELECT\n",
        "    SUM(try_cast(replace(`GHG emissions mtons CO2e`, ',', '') as double)) as total_emissions,\n",
        "    SUM(population) as total_population,\n",
        "    COUNT(DISTINCT state_abbr) as num_states\n",
        "  FROM\n",
        "    emissions_data_2023\n",
        ")\n",
        "SELECT\n",
        "  total_emissions,\n",
        "  total_population,\n",
        "  num_states,\n",
        "  total_emissions / total_population as avg_emissions_per_person,\n",
        "  (\n",
        "    SELECT\n",
        "      top_10_sum\n",
        "    FROM\n",
        "      top_10_total\n",
        "  )\n",
        "    / total_emissions as top_10_pct\n",
        "FROM\n",
        "  overall_stats"
      ]
    }
  ],
